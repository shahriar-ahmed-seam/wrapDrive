{
  "name": "@wrapdrive/node-peer",
  "version": "0.1.0",
  "private": true,
  "description": "Node host for a WrapDrive peer: discovery, HTTP receive server, and sender. Shared by the desktop main process and the web-host bridge.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean"
  },
  "dependencies": {
    "@wrapdrive/protocol": "workspace:*",
    "@wrapdrive/transfer-engine": "workspace:*"
  }
}
