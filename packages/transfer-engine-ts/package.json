{
  "name": "@wrapdrive/transfer-engine",
  "version": "0.1.0",
  "private": true,
  "description": "WrapDrive transfer engine: chunk planning, parallel send scheduling, implicit reassembly, and single-stream fallback.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean"
  },
  "dependencies": {
    "@wrapdrive/protocol": "workspace:*"
  }
}
