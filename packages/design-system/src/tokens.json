{
  "$meta": {
    "name": "WrapDrive Design Tokens",
    "version": "0.1.0",
    "description": "Single source of design truth shared by Android, Desktop, and Web."
  },
  "color": {
    "brand": {
      "primary": "#5B8DEF",
      "primaryHover": "#4F7FE0",
      "primaryActive": "#4571CC",
      "onPrimary": "#FFFFFF",
      "accent": "#6FE3C2",
      "onAccent": "#06231C"
    },
    "dark": {
      "background": "#0E1117",
      "surface": "#161B22",
      "surfaceRaised": "#1C232D",
      "surfaceOverlay": "#232C38",
      "border": "#2A3340",
      "textPrimary": "#E6EDF3",
      "textSecondary": "#9DA7B3",
      "textMuted": "#6B7682"
    },
    "light": {
      "background": "#F5F7FA",
      "surface": "#FFFFFF",
      "surfaceRaised": "#FFFFFF",
      "surfaceOverlay": "#EEF1F5",
      "border": "#D8DEE6",
      "textPrimary": "#1A1F26",
      "textSecondary": "#4A5563",
      "textMuted": "#7A858F"
    },
    "status": {
      "success": "#3FB950",
      "warning": "#D29922",
      "danger": "#F85149",
      "info": "#58A6FF"
    }
  },
  "spacing": {
    "none": 0,
    "xxs": 2,
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "xxl": 32,
    "xxxl": 48
  },
  "radius": {
    "none": 0,
    "sm": 6,
    "md": 10,
    "lg": 16,
    "xl": 24,
    "pill": 999
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter, 'Segoe UI', Roboto, system-ui, sans-serif",
      "mono": "'JetBrains Mono', 'SF Mono', Consolas, monospace"
    },
    "size": {
      "caption": 12,
      "body": 14,
      "bodyLarge": 16,
      "title": 20,
      "headline": 28,
      "display": 36
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.7
    }
  },
  "elevation": {
    "none": "none",
    "sm": "0 1px 2px rgba(0,0,0,0.24)",
    "md": "0 4px 12px rgba(0,0,0,0.32)",
    "lg": "0 12px 32px rgba(0,0,0,0.40)"
  },
  "motion": {
    "duration": {
      "instant": 80,
      "fast": 150,
      "normal": 240,
      "slow": 400
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "decelerate": "cubic-bezier(0, 0, 0, 1)",
      "accelerate": "cubic-bezier(0.3, 0, 1, 1)",
      "emphasized": "cubic-bezier(0.2, 0, 0, 1.2)"
    }
  }
}
